# =============================================================================
# AI Tool Roadmapper — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
#
# Full setup instructions: docs/setup-supabase.md
# =============================================================================


# -----------------------------------------------------------------------------
# Anthropic
# Get your API key at: https://console.anthropic.com/settings/api-keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=


# -----------------------------------------------------------------------------
# Supabase
# Find these in your Supabase project dashboard under:
#   Settings → API → Project URL / Project API keys
#
# NEXT_PUBLIC_SUPABASE_URL      — Your project URL (safe to expose to browser)
# NEXT_PUBLIC_SUPABASE_ANON_KEY — Anonymous (public) key (safe to expose)
# SUPABASE_SERVICE_ROLE_KEY     — Service role key (KEEP SECRET — server only)
#
# DATABASE_URL — Direct PostgreSQL connection string.
#   Found in: Settings → Database → Connection string → URI
#   Format:   postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#   Note:     Use the "Transaction" pooler URL for serverless/edge environments.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=


# -----------------------------------------------------------------------------
# Inngest
# Get your keys at: https://app.inngest.com → your app → Manage → Keys
#
# INNGEST_EVENT_KEY  — Used to send events to Inngest
# INNGEST_SIGNING_KEY — Used to verify webhook signatures from Inngest
#
# For local development with the Inngest Dev Server (npx inngest-cli@latest dev),
# you can leave these empty — the dev server does not require real keys.
# -----------------------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=


# -----------------------------------------------------------------------------
# App
# NEXT_PUBLIC_APP_URL — The canonical URL of your deployment.
#   Local:      http://localhost:3000
#   Production: https://your-domain.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
